<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <Target Name="ILRepacker" AfterTargets="Build">
        <PropertyGroup>
            <WorkingDirectory>$(OutputPath)</WorkingDirectory>
        </PropertyGroup>
        <ItemGroup>
            <InputAssemblies Include="$(OutputPath)/$(AssemblyName).dll" />
            <InputAssemblies Include="$(OutputPath)/Buttplug.dll" />
            <InputAssemblies Include="$(OutputPath)/deniszykov.WebSocketListener.dll" />
            <IlRepackLibs Include="$(OutputPath)" />
        </ItemGroup>
        <Message Text="MERGING: @(InputAssemblies->'%(Filename)') into $(OutputAssembly)" Importance="High" />
        <ILRepack Internalize="false" LibraryPath="@(IlRepackLibs)" OutputFile="$(OutputPath)/merged/$(AssemblyName).dll" InputAssemblies="@(InputAssemblies)" />
    </Target>
    <Target Name="CopyFinalMod" AfterTargets="ILRepacker">
        <Copy SourceFiles="$(OutDir)/merged/AdultToyAPI.dll" DestinationFolder="../Output/" ContinueOnError="true" />
    </Target>
</Project>